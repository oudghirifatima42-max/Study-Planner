<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#1a3a2a">

    <!-- icone (book) + Titre -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📚"
        android:textSize="72sp"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Study Planner"
        android:textSize="30sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Planificateur de révisions"
        android:textSize="14sp"
        android:textColor="#A7F3D0"
        android:layout_marginBottom="48dp"/>

    <!-- Champ nom -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Entrez votre nom"
        android:textSize="14sp"
        android:textColor="#A7F3D0"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/etNomEtudiant"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:hint="ex : Fatima zahra"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:textColorHint="#6B9E82"
        android:background="#2d5a3d"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:inputType="textPersonName"
        android:layout_marginBottom="24dp"/>

    <Button
        android:id="@+id/btnCommencer"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Commencer"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="#A7F3D0"
        android:textColor="#1a3a2a"/>

</LinearLayout>